{
  "name": "@stakeswky/healthclaw",
  "version": "1.0.1",
  "description": "HealthClaw data plugin — encrypted iOS health sync + AI analysis",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./install-core/run-install-core": {
      "types": "./dist/install-core/run-install-core.d.ts",
      "import": "./dist/install-core/run-install-core.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "bootstrap:install": "node scripts/bootstrap-install.mjs"
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.48",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "qrcode": "^1.5.4",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
